# Red del servidor web
HOST=0.0.0.0
PORT=8000

# Fuente RTSP
RTSP_URL=rtsp://usuario:password@192.168.1.100:554/stream1
# auto (prueba udp->tcp), udp, tcp
RTSP_TRANSPORT=auto

# Modelo YOLO11 recomendado para Jetson Orin Nano (rendimiento/latencia)
MODEL_PATH=yolo11n.pt
# auto (GPU si está disponible), 0 (CUDA:0), cpu
DEVICE=auto

# Umbrales de inferencia
CONF_THRESHOLD=0.35
IOU_THRESHOLD=0.45
IMG_SIZE=640

# Compresion del stream MJPEG
JPEG_QUALITY=80
RECONNECT_DELAY_SEC=2

# COCO classes
PERSON_CLASS_ID=0
# Vehiculos (sin bicicleta=1 ni motocicleta/scooter=3)
VEHICLE_CLASS_IDS=2,5,7,6
