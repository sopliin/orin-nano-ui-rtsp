# Red del servidor web
HOST=0.0.0.0
PORT=8000

# Fuente de video: URL RTSP o ruta absoluta a un archivo de video en la Jetson
# Ejemplos:
#   VIDEO_SOURCE=rtsp://usuario:password@192.168.1.100:554/stream1
#   VIDEO_SOURCE=/home/jetson/videos/prueba.mp4
VIDEO_SOURCE=rtsp://usuario:password@192.168.1.100:554/stream1

# Solo aplica cuando VIDEO_SOURCE es RTSP — auto (prueba udp->tcp), udp, tcp
RTSP_TRANSPORT=auto

# Ruta al modelo YOLOv5n custom (.pt). Coloca el archivo en weights/
MODEL_PATH=weights/yolov5n_custom.pt
# auto (GPU si está disponible), 0 (CUDA:0), cpu
DEVICE=auto

# Umbrales de inferencia
CONF_THRESHOLD=0.35
IOU_THRESHOLD=0.45
IMG_SIZE=640

# Compresion del stream MJPEG
JPEG_QUALITY=80
RECONNECT_DELAY_SEC=2

# Clases del modelo custom — ajusta según el dataset con el que fue entrenado
PERSON_CLASS_ID=0
# IDs de clases de vehículos (puede ser solo "1" si el modelo tiene 2 clases)
VEHICLE_CLASS_IDS=1
